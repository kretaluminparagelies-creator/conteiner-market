# Copy to .env.local and fill in values from Supabase → Settings → API
# Same vars as Vercel → Settings → Environment Variables

# Public site URL (production or http://localhost:3000 for local dev)
NEXT_PUBLIC_SITE_URL=

# Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase → Secret key (sb_secret_...) — server only, never commit real value
SUPABASE_SERVICE_ROLE_KEY=

# Resend — copy RESEND_API_KEY from LogiWork project (.env.local or Supabase Edge secrets)
RESEND_API_KEY=

# Where new contact-form emails are sent (default: support@logiworkpass.com)
LEAD_NOTIFY_EMAIL=support@logiworkpass.com

# Optional sender (default: Container Market <support@logiworkpass.com>)
# EMAIL_FROM=Container Market <support@logiworkpass.com>

# Cloudflare Turnstile (contact form anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
